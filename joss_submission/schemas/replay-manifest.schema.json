{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:atu:schema:replay-manifest:0.2.0",
  "title": "ATU Replay Manifest",
  "type": "object",
  "required": ["episode_id", "replay_class", "environment", "tools", "receipts", "redaction_policy"],
  "properties": {
    "episode_id": { "type": "string" },
    "replay_class": {
      "type": "string",
      "enum": ["deterministic", "semi_deterministic", "receipt_only"]
    },
    "environment": {
      "type": "object",
      "additionalProperties": true
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["tool_name", "step_count", "side_effect_count"],
        "properties": {
          "tool_name": { "type": "string" },
          "step_count": { "type": "integer", "minimum": 0 },
          "side_effect_count": { "type": "integer", "minimum": 0 }
        },
        "additionalProperties": false
      }
    },
    "receipts": {
      "type": "array",
      "items": { "$ref": "receipt.schema.json" }
    },
    "redaction_policy": {
      "type": "string",
      "enum": ["none", "standard", "strict"]
    }
  },
  "additionalProperties": false
}
