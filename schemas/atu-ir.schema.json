{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:atu:schema:atu-ir:0.2.0",
  "title": "ATU Intermediate Representation",
  "type": "object",
  "required": ["atu_version", "source_trace", "episode", "execution", "replay", "labels"],
  "properties": {
    "atu_version": {
      "type": "string",
      "pattern": "^0\\.2\\.[0-9]+$"
    },
    "source_trace": {
      "type": "object",
      "required": ["schema", "trace_id"],
      "properties": {
        "schema": {
          "type": "string",
          "enum": ["opentelemetry", "openinference", "langsmith"]
        },
        "trace_id": { "type": "string" },
        "root_span_id": { "type": ["string", "null"] },
        "framework": { "type": ["string", "null"] },
        "project": { "type": ["string", "null"] },
        "thread_id": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "episode": {
      "type": "object",
      "required": ["episode_id", "task_context"],
      "properties": {
        "episode_id": { "type": "string" },
        "parent_episode_id": { "type": ["string", "null"] },
        "task_context": {
          "type": "object",
          "required": ["task_type", "goal", "constraints"],
          "properties": {
            "task_type": { "type": ["string", "null"] },
            "goal": { "type": ["string", "null"] },
            "constraints": {
              "type": "array",
              "items": { "type": "string" }
            },
            "policy_context": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "additionalProperties": false
        },
        "agent_profile": {
          "type": "object",
          "properties": {
            "agent_role": { "type": ["string", "null"] },
            "agent_name": { "type": ["string", "null"] },
            "persona": { "type": ["string", "null"] },
            "metadata": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "execution": {
      "type": "object",
      "required": ["steps", "evidence_edges", "tool_receipts"],
      "properties": {
        "steps": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["step_id", "kind", "start_time", "end_time"],
            "properties": {
              "step_id": { "type": "string" },
              "span_id": { "type": ["string", "null"] },
              "parent_step_id": { "type": ["string", "null"] },
              "kind": {
                "type": "string",
                "enum": ["agent", "llm", "tool", "retriever", "chain", "guardrail", "evaluator", "prompt", "other"]
              },
              "name": { "type": ["string", "null"] },
              "tool_name": { "type": ["string", "null"] },
              "input_ref": { "type": ["string", "null"] },
              "output_ref": { "type": ["string", "null"] },
              "start_time": { "type": "string", "format": "date-time" },
              "end_time": { "type": "string", "format": "date-time" },
              "latency_ms": {
                "type": ["integer", "null"],
                "minimum": 0
              },
              "cost_usd": {
                "type": ["number", "null"],
                "minimum": 0
              },
              "status": {
                "type": ["string", "null"],
                "enum": ["ok", "error", "unset", null]
              },
              "metadata": {
                "type": "object",
                "additionalProperties": true
              }
            },
            "additionalProperties": false
          }
        },
        "evidence_edges": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["from_step", "relation"],
            "properties": {
              "from_step": { "type": "string" },
              "to_claim": { "type": ["string", "null"] },
              "to_step": { "type": ["string", "null"] },
              "relation": {
                "type": "string",
                "enum": ["supports", "produces", "derives", "fails", "uses"]
              },
              "confidence": {
                "type": ["number", "null"],
                "minimum": 0,
                "maximum": 1
              }
            },
            "additionalProperties": false
          }
        },
        "tool_receipts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["receipt_id", "step_id", "tool_name", "timestamp", "result_digest"],
            "properties": {
              "receipt_id": { "type": "string" },
              "step_id": { "type": "string" },
              "tool_name": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" },
              "input_digest": { "type": ["string", "null"] },
              "result_digest": { "type": "string" },
              "side_effect": { "type": "boolean" },
              "idempotency_key": { "type": ["string", "null"] },
              "uri": { "type": ["string", "null"] }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "replay": {
      "type": "object",
      "required": ["class", "redaction_policy"],
      "properties": {
        "class": {
          "type": "string",
          "enum": ["deterministic", "semi_deterministic", "receipt_only"]
        },
        "manifest_ref": { "type": ["string", "null"] },
        "redaction_policy": {
          "type": "string",
          "enum": ["none", "standard", "strict"]
        },
        "privacy_tier": {
          "type": ["string", "null"],
          "enum": ["public", "internal", "restricted", null]
        }
      },
      "additionalProperties": false
    },
    "labels": {
      "type": "object",
      "required": ["success", "cost_usd", "latency_ms", "replay_class"],
      "properties": {
        "success": { "type": ["boolean", "null"] },
        "failure_mode": { "type": ["string", "null"] },
        "failure_origin_step": { "type": ["string", "null"] },
        "cost_usd": {
          "type": ["number", "null"],
          "minimum": 0
        },
        "latency_ms": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "redundancy_score": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 1
        },
        "provenance_completeness": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 1
        },
        "quality_score": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 1
        },
        "policy_violation": { "type": ["boolean", "null"] },
        "replay_class": {
          "type": "string",
          "enum": ["deterministic", "semi_deterministic", "receipt_only"]
        }
      },
      "additionalProperties": false
    },
    "citation": {
      "type": "object",
      "properties": {
        "dataset": { "type": ["string", "null"] },
        "split": {
          "type": ["string", "null"],
          "enum": ["train", "eval", "test", null]
        },
        "software_doi": { "type": ["string", "null"] },
        "dataset_doi": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
